# Required
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
FAL_API_KEY=

# Optional — AWS S3 (falls back to local storage if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_PRIVATE_BUCKET=hebrew-shorts-private
AWS_S3_PUBLIC_BUCKET=hebrew-shorts-public

# Optional — Social Publishing
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER_ID=

# Optional — Server Config
MAX_CONCURRENT_JOBS=3
JOB_RETENTION_SECONDS=3600
ALLOWED_ORIGINS=https://yourdomain.com
